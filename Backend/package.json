{
  "name": "hng-crm-backend",
  "version": "1.0.0",
  "description": "HNG CRM Backend — Node.js + Express + MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "predev": "node -e \"require('kill-port')(7007).catch(()=>{})\"",
